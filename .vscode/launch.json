{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "justMyCode": false,
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: run_benchmark.py with config_test.yaml",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run_benchmark.py",
            "args": ["--config", "benchmark_configs/config_test.yaml"],
            "justMyCode": false,
            "console": "integratedTerminal"
        }
    ]
}
